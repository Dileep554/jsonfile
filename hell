import re
import sys

if len(sys.argv) < 2:
    print("Usage: python3 generate_destroy_targets.py <terraform_log_file>")
    sys.exit(1)

log_file = sys.argv[1]

pattern = re.compile(
    r'^(?P<resource>[a-zA-Z0-9_]+\.[a-zA-Z0-9_\-]+): Destruction complete',
    re.MULTILINE
)

with open(log_file, 'r', encoding='utf-8', errors='ignore') as f:
    content = f.read()

resources = sorted(set(
    f'-target={match.group("resource")}'
    for match in pattern.finditer(content)
))

if not resources:
    print("No destroyed resources found.")
    sys.exit(0)

print(" ".join(resources))

with open("destroy_targets.txt", "w") as f:
    for r in resources:
        f.write(r + "\n")
